{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "Womenhenku",
  "version": "0.2.0",
  "identifier": "com.womenhenku.app",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "cd ../src-ui && npm run dev",
    "beforeBuildCommand": "cd ../src-ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Womenhenku",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
